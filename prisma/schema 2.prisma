generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ratings   Rating[]
  listItems PersonalListItem[]
}

model Content {
  id         String   @id @default(cuid())
  externalId String   @unique
  title      String
  type       String
  posterUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ratings   Rating[]
  listItems PersonalListItem[]
}

model Rating {
  id        String   @id @default(cuid())
  score     Int
  comment   String?
  userId    String
  contentId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model PersonalList {
  id        String   @id @default(cuid())
  name      String
  type      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listItems PersonalListItem[]

  @@unique([userId, type])
}

model PersonalListItem {
  id             String   @id @default(cuid())
  personalListId  String
  contentId      String
  createdAt      DateTime @default(now())

  personalList PersonalList @relation(fields: [personalListId], references: [id], onDelete: Cascade)
  content      Content      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([personalListId, contentId])
}